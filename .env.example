# Cards Against Bhayanak — environment template.
#
# Copy to `.env` for a local full-stack `docker compose up`, or set these as
# stack environment variables in Dockhand. Dockhand injects vars into the
# `docker compose` process for ${VAR} interpolation; this compose file
# already references each one under `environment:`, so they reach the
# containers. DATABASE_URL / REDIS_URL are derived in compose — don't set them.

# ── Required (compose fails fast with `:?` if unset) ─────────────────────────
# Postgres password. Used by the postgres service and the app's DATABASE_URL.
POSTGRES_PASSWORD=change-me

# HMAC secret for session tokens. MUST be 32+ chars and unguessable —
# a weak value makes session tokens forgeable. Generate:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-32-plus-char-random-string

# ── Optional (sensible defaults in compose) ──────────────────────────────────
# Host/container port. Default: 3000
# PORT=3000

# Default: production (this is the prod image; production enforces rate
# limiting). Only set to `development` for non-prod experiments.
# NODE_ENV=production

# Log shipping to Axiom (prod only). Omit to disable.
# AXIOM_TOKEN=
# AXIOM_DATASET=

# PostHog product analytics / session replay / error tracking. Omit to
# disable analytics. Host default: https://us.i.posthog.com
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# Build-time only (Dockerfile ARG): uploads sourcemaps to PostHog during
# `docker build`. Not read at runtime. Omit to skip the upload.
# POSTHOG_PERSONAL_API_KEY=
